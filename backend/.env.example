NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
# MongoDB — Docker local (docker compose up -d mongo)
MONGO_URI=mongodb://localhost:27017/qnas
# Si usas MongoDB Atlas, reemplaza por tu cadena:
# MONGO_URI=mongodb+srv://usuario:password@cluster.xxxxx.mongodb.net/qnas

# JWT — cambia el secreto por uno largo y aleatorio en producción
JWT_SECRET=cambia-esto-por-un-secreto-muy-largo-y-aleatorio
JWT_EXPIRES_IN=7d

# ── Almacenamiento de archivos ──────────────────────────────
# DEJA ESTO VACÍO para usar el disco local (desarrollo).
# Para producción (Cloudflare R2 / S3), complétalo y el sistema
# guardará y servirá los archivos desde la nube automáticamente.
# S3_BUCKET=mmm-archivos
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY_ID=tu-access-key
# S3_SECRET_ACCESS_KEY=tu-secret-key
# S3_PUBLIC_URL=https://pub-xxxx.r2.dev   (URL pública del bucket)
